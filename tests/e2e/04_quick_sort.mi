// Quick Sort algorithm implementation.

use system.io
use system.time
use system.collections.list


fn partition(arr List<int>, low int, high int) int
    var a = arr
    let pivot = a[high]
    var i = low - 1
    var j = low
    while j < high
        if arr[j] <= pivot
            i += 1
            let temp = a[i]
            a[i] = a[j]
            a[j] = temp
        j += 1
    
    let temp = a[i + 1]
    a[i + 1] = a[high]
    a[high] = temp
    return i + 1

fn quick_sort(arr List<int>, low int, high int)
    var a = arr
    if low < high
        let pivot_idx = partition(a, low, high)
        quick_sort(a, low, pivot_idx - 1)
        quick_sort(a, pivot_idx + 1, high)

fn main()
    let data = List<int>([10, 80, 30, 90, 40, 50, 70])
    
    print("Unsorted list: ")
    for x in data: print(f"{x} ")
    println()
    
    let start = nanotime()
    quick_sort(data, 0, data.length() - 1)
    let end = nanotime()
    
    print("Sorted list:   ")
    for x in data: print(f"{x} ")
    println()
    println(f"Time taken: {end - start} ns")
