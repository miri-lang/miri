// Fibonacci sequence implementation (recursive and iterative) and performance test.

use system.io
use system.time

fn fib_recursive(n int) int
    if n <= 1: return n
    return fib_recursive(n - 1) + fib_recursive(n - 2)

fn fib_iterative(n int) int
    if n <= 1: return n
    var a = 0
    var b = 1
    var i = 2
    while i <= n
        let temp = a + b
        a = b
        b = temp
        i += 1
    return b

fn main()
    let n = 20
    
    let start_rec = nanotime()
    let res_rec = fib_recursive(n)
    let end_rec = nanotime()
    
    let start_ite = nanotime()
    let res_ite = fib_iterative(n)
    let end_ite = nanotime()
    
    println(f"Fibonacci({n}) = {res_rec}")
    println(f"Recursive time: {end_rec - start_rec} ns")
    println(f"Iterative time: {end_ite - start_ite} ns")
