// Matrix Multiplication implementation.

use system.io
use system.time
use system.collections.array

fn main()
    let size = 3
    var a = [1, 2, 3, 4, 5, 6, 7, 8, 9]
    var b = [9, 8, 7, 6, 5, 4, 3, 2, 1]
    var c = [0, 0, 0, 0, 0, 0, 0, 0, 0]
    
    let start = nanotime()
    var i = 0
    while i < size
        var j = 0
        while j < size
            var k = 0
            var sum = 0
            while k < size
                let val_a = a.element_at(i * size + k)
                let val_b = b.element_at(k * size + j)
                sum = sum + (val_a * val_b)
                k += 1
            c.set(i * size + j, sum)
            j += 1
        i += 1
    let end = nanotime()
    
    println("Result Matrix:")
    var r = 0
    while r < size
        var col = 0
        while col < size
            print(f"{c.element_at(r * size + col)} ")
            col += 1
        println()
        r += 1
    
    println(f"Time taken: {end - start} ns")
