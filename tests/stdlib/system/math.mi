//
// Tests for `system.math` intrinsics and constants.
//
// Note: `use system.math as M` is used for the constants because the
// unqualified `let X = <module-const>` path is currently mis-typed by the
// compiler (constant comes through as i64 even when declared as float).
// Tracked separately; once fixed, the qualified prefix can be dropped.

use system.io
use system.math as M
use system.testing

fn approx(a float, b float) bool
    let diff = a - b
    if diff < 0.0
        return -diff < 0.0001
    return diff < 0.0001

fn test_abs()
    assert_eq(M.abs(3.0), 3.0)
    assert_eq(M.abs(-3.5), 3.5)
    assert_eq(M.abs(0.0), 0.0)

fn test_min_max()
    assert_eq(M.min(1.0, 2.0), 1.0)
    assert_eq(M.min(-5.0, -2.0), -5.0)
    assert_eq(M.max(1.0, 2.0), 2.0)
    assert_eq(M.max(-5.0, -2.0), -2.0)
    assert_eq(M.min(4.2, 4.2), 4.2, "equal values: min returns either")
    assert_eq(M.max(4.2, 4.2), 4.2)

fn test_pow_and_sqrt()
    assert_eq(M.pow(2.0, 10.0), 1024.0)
    assert_eq(M.pow(5.0, 0.0), 1.0, "x^0 == 1")
    assert_eq(M.pow(1.0, 99.0), 1.0)
    assert_eq(M.sqrt(0.0), 0.0)
    assert_eq(M.sqrt(16.0), 4.0)
    assert(approx(M.sqrt(2.0), 1.41421356), "sqrt(2)")

fn test_rounding()
    assert_eq(M.floor(3.7), 3.0)
    assert_eq(M.floor(-3.2), -4.0, "floor rounds toward -∞")
    assert_eq(M.ceil(3.2), 4.0)
    assert_eq(M.ceil(-3.7), -3.0, "ceil rounds toward +∞")
    assert_eq(M.round(3.4), 3.0)
    assert_eq(M.round(3.5), 4.0, "round halfway → up")
    assert_eq(M.round(-3.5), -4.0)

fn test_trig()
    assert(approx(M.sin(0.0), 0.0))
    assert(approx(M.cos(0.0), 1.0))
    assert(approx(M.tan(0.0), 0.0))
    assert(approx(M.sin(M.PI / 2.0), 1.0), "sin(π/2) == 1")
    assert(approx(M.cos(M.PI), -1.0), "cos(π) == -1")

fn test_log_and_exp()
    assert(approx(M.log(1.0), 0.0), "ln(1) == 0")
    assert(approx(M.exp(0.0), 1.0), "exp(0) == 1")
    assert(approx(M.log(M.E), 1.0), "ln(e) == 1")
    assert(approx(M.exp(M.log(7.0)), 7.0), "exp(ln(x)) == x")

fn test_constants()
    assert(approx(M.PI, 3.14159265), "PI within tolerance")
    assert(approx(M.E, 2.71828182), "E within tolerance")
    assert(M.INF > 1e300, "INF is large")

fn test_transcendental()
    assert(approx(M.tanh(0.0), 0.0), "tanh(0) == 0")
    assert(approx(M.tanh(1.0), 0.7615942), "tanh(1)")
    assert(approx(M.exp2(3.0), 8.0), "exp2(3) == 8")
    assert(approx(M.log2(8.0), 3.0), "log2(8) == 3")
    assert(approx(M.atan2(1.0, 1.0), 0.7853982), "atan2(1,1) == π/4")
    assert(approx(M.fract(2.25), 0.25), "fract(2.25)")
    assert(approx(M.sign(-3.0), -1.0), "sign(neg) == -1")
    assert(approx(M.sign(2.0), 1.0), "sign(pos) == 1")
    assert(approx(M.sign(0.0), 0.0), "sign(0) == 0")

fn test_blend()
    assert(approx(M.clamp(5.0, 0.0, 1.0), 1.0), "clamp above hi")
    assert(approx(M.clamp(-1.0, 0.0, 1.0), 0.0), "clamp below lo")
    assert(approx(M.clamp(0.5, 0.0, 1.0), 0.5), "clamp inside")
    assert(approx(M.mix(0.0, 10.0, 0.25), 2.5), "mix quarter")
    assert(approx(M.smoothstep(0.0, 1.0, 0.5), 0.5), "smoothstep midpoint")
    assert(approx(M.step(0.5, 0.3), 0.0), "step below edge")
    assert(approx(M.step(0.5, 0.7), 1.0), "step at/above edge")

fn test_sigmoid()
    assert(approx(M.sigmoid(0.0), 0.5), "sigmoid(0) == 0.5")
    assert(approx(M.sigmoid(1.0), 0.7310586), "sigmoid(1)")
    assert(M.sigmoid(20.0) > 0.99, "sigmoid saturates to 1")
    assert(M.sigmoid(-20.0) < 0.01, "sigmoid saturates to 0")

fn test_hash_and_noise()
    // hash_u32 is deterministic and the all-zero seed is the fixed point.
    assert(M.hash_u32(5 as u32) == M.hash_u32(5 as u32), "hash is deterministic")
    assert(M.hash_u32(0 as u32) == 0 as u32, "hash(0) == 0")
    assert(M.hash_u32(1 as u32) != M.hash_u32(2 as u32), "adjacent seeds differ")
    // value_noise stays in [0, 1), is deterministic, and handles negatives.
    let n = M.value_noise(2.3, 5.7)
    assert(n >= 0.0 and n < 1.0, "value_noise in [0,1)")
    assert(approx(M.value_noise(2.3, 5.7), n), "value_noise deterministic")
    let neg = M.value_noise(-3.4, -1.2)
    assert(neg >= 0.0 and neg < 1.0, "value_noise handles negative coords")
    // fbm and curl compose without error.
    assert(approx(M.fbm(1.0, 2.0), M.fbm(1.0, 2.0)), "fbm deterministic")
    assert(approx(M.curl_noise_x(1.0, 2.0), M.curl_noise_x(1.0, 2.0)), "curl_x deterministic")
    assert(approx(M.curl_noise_y(1.0, 2.0), M.curl_noise_y(1.0, 2.0)), "curl_y deterministic")

fn main()
    test_abs()
    test_min_max()
    test_pow_and_sqrt()
    test_rounding()
    test_trig()
    test_log_and_exp()
    test_constants()
    test_transcendental()
    test_blend()
    test_sigmoid()
    test_hash_and_noise()
    println("system.math: OK")
