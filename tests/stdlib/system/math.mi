//
// Tests for `system.math` intrinsics and constants.
//
// Note: `use system.math as M` is used for the constants because the
// unqualified `let X = <module-const>` path is currently mis-typed by the
// compiler (constant comes through as i64 even when declared as float).
// Tracked separately; once fixed, the qualified prefix can be dropped.

use system.io
use system.math as M
use system.testing

fn approx(a float, b float) bool
    let diff = a - b
    if diff < 0.0
        return -diff < 0.0001
    return diff < 0.0001

fn test_abs()
    assert_eq(M.abs(3.0), 3.0)
    assert_eq(M.abs(-3.5), 3.5)
    assert_eq(M.abs(0.0), 0.0)

fn test_min_max()
    assert_eq(M.min(1.0, 2.0), 1.0)
    assert_eq(M.min(-5.0, -2.0), -5.0)
    assert_eq(M.max(1.0, 2.0), 2.0)
    assert_eq(M.max(-5.0, -2.0), -2.0)
    assert_eq(M.min(4.2, 4.2), 4.2, "equal values: min returns either")
    assert_eq(M.max(4.2, 4.2), 4.2)

fn test_pow_and_sqrt()
    assert_eq(M.pow(2.0, 10.0), 1024.0)
    assert_eq(M.pow(5.0, 0.0), 1.0, "x^0 == 1")
    assert_eq(M.pow(1.0, 99.0), 1.0)
    assert_eq(M.sqrt(0.0), 0.0)
    assert_eq(M.sqrt(16.0), 4.0)
    assert(approx(M.sqrt(2.0), 1.41421356), "sqrt(2)")

fn test_rounding()
    assert_eq(M.floor(3.7), 3.0)
    assert_eq(M.floor(-3.2), -4.0, "floor rounds toward -∞")
    assert_eq(M.ceil(3.2), 4.0)
    assert_eq(M.ceil(-3.7), -3.0, "ceil rounds toward +∞")
    assert_eq(M.round(3.4), 3.0)
    assert_eq(M.round(3.5), 4.0, "round halfway → up")
    assert_eq(M.round(-3.5), -4.0)

fn test_trig()
    assert(approx(M.sin(0.0), 0.0))
    assert(approx(M.cos(0.0), 1.0))
    assert(approx(M.tan(0.0), 0.0))
    assert(approx(M.sin(M.PI / 2.0), 1.0), "sin(π/2) == 1")
    assert(approx(M.cos(M.PI), -1.0), "cos(π) == -1")

fn test_log_and_exp()
    assert(approx(M.log(1.0), 0.0), "ln(1) == 0")
    assert(approx(M.exp(0.0), 1.0), "exp(0) == 1")
    assert(approx(M.log(M.E), 1.0), "ln(e) == 1")
    assert(approx(M.exp(M.log(7.0)), 7.0), "exp(ln(x)) == x")

fn test_constants()
    assert(approx(M.PI, 3.14159265), "PI within tolerance")
    assert(approx(M.E, 2.71828182), "E within tolerance")
    assert(M.INF > 1e300, "INF is large")

fn main()
    test_abs()
    test_min_max()
    test_pow_and_sqrt()
    test_rounding()
    test_trig()
    test_log_and_exp()
    test_constants()
    println("system.math: OK")
