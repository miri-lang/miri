//
// Smoke tests for `system.io`. IO is side-effecting, so we mainly check that
// the calls execute and `line_end` returns a sensible platform terminator.

use system.io
use system.testing

fn test_print_and_println()
    print("io: ")
    println("printed")

fn test_eprint_and_eprintln()
    eprint("io.err: ")
    eprintln("(this stderr line is expected)")

fn test_line_end_is_platform_terminator()
    let le = line_end()
    assert(le.length() > 0, "line_end is non-empty")
    assert(le.length() <= 2, "line_end is at most CRLF length")
    assert(le == "\n" or le == "\r\n", "line_end matches a known platform terminator")

fn main()
    test_print_and_println()
    test_eprint_and_eprintln()
    test_line_end_is_platform_terminator()
    println("system.io: OK")
