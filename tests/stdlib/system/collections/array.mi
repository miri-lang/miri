// Tests for `system.collections.array`. Arrays are fixed-size; the surface
// covered is read / write at index, contains / index_of from `Queryable<T>`,
// sort / reverse and clone.

use system.collections.array
use system.testing

fn test_literal_construction()
    let a = [10, 20, 30, 40]
    assert_eq(a.length(), 4)
    assert(not a.is_empty())
    assert_eq(a.element_at(0), 10)
    assert_eq(a.element_at(3), 40)
    assert_eq(a.element_at(2), 30)

fn test_indexed_write()
    var b = [1, 2, 3]
    b.set(1, 99)
    assert_eq(b.element_at(1), 99)
    b[0] = 7
    assert_eq(b.element_at(0), 7, "index-write syntax also works")

fn test_contains_and_index_of()
    let probe = [4, 5, 6, 5]
    assert(probe.contains(5))
    assert(not probe.contains(42))
    assert_eq(probe.index_of(5), 1)
    assert_eq(probe.index_of(42), -1)

fn test_first_and_last()
    let probe = [4, 5, 6, 5]
    assert_eq(probe.first() ?? -1, 4)
    assert_eq(probe.last() ?? -1, 5)

fn test_reverse_in_place()
    var rev = [1, 2, 3, 4]
    rev.reverse()
    assert_eq(rev.length(), 4)
    assert_eq(rev.element_at(0), 4)
    assert_eq(rev.element_at(1), 3)
    assert_eq(rev.element_at(2), 2)
    assert_eq(rev.element_at(3), 1)

fn test_sort_ascending()
    var sortable = [3, 1, 4, 1, 5, 9, 2, 6]
    sortable.sort()
    assert_eq(sortable.element_at(0), 1)
    assert_eq(sortable.element_at(7), 9)
    var i = 1
    while i < sortable.length()
        assert(sortable.element_at(i - 1) <= sortable.element_at(i))
        i += 1

fn test_clone_is_independent()
    var src = [1, 2, 3]
    let dup = src.clone()
    src.set(0, 99)
    assert_eq(dup.element_at(0), 1, "clone unaffected by source mutation")
    assert_eq(src.element_at(0), 99)

fn test_for_loop_iteration()
    var sum = 0
    for x in [10, 20, 30]
        sum = sum + x
    assert_eq(sum, 60)

fn main()
    test_literal_construction()
    test_indexed_write()
    test_contains_and_index_of()
    test_first_and_last()
    test_reverse_in_place()
    test_sort_ascending()
    test_clone_is_independent()
    test_for_loop_iteration()
    println("system.collections.array: OK")
