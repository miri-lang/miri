//
// Self-tests for `system.testing` — the assertion intrinsics dogfooded against
// themselves. Every assertion below is on the happy path: a failure here means
// the assertion harness itself is broken.

use system.io
use system.testing

fn test_assert_true()
    assert(true)
    assert(true, "with message")
    assert(1 + 1 == 2)
    assert(1 < 2)

fn test_assert_eq_primitives()
    assert_eq(7, 7)
    assert_eq(true, true)
    assert_eq("hi", "hi")
    assert_eq(1.5, 1.5)

fn test_assert_eq_typed_ints()
    let a i32 = 9
    let b i32 = 9
    assert_eq(a, b)
    let u u32 = 5
    let v u32 = 5
    assert_eq(u, v)

fn test_assert_ne()
    assert_ne(1, 2)
    assert_ne("a", "b")
    assert_ne(true, false)

fn test_assert_panics()
    assert_panics(fn(): panic("planned failure"))
    assert_panics(fn(): panic("division by zero"), "division")

fn main()
    test_assert_true()
    test_assert_eq_primitives()
    test_assert_eq_typed_ints()
    test_assert_ne()
    test_assert_panics()
    println("system.testing: OK")
