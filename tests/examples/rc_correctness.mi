// RC Correctness Test
// This test verifies that managed types (String) can be assigned and passed around.
// The Perceus pass should insert IncRef/DecRef instructions.
// Since the interpreter currently stubs these instructions, we mainly verify
// that the pipeline lowers and executes without crashing.

fn consume(s string)
    // Consumes s (ref count decrement at end of scope)

fn main()
    let s1 = "Hello, World!"
    
    // Assignment (IncRef)
    let s2 = s1
    
    // Pass to function (IncRef)
    consume(s2)
    
    // s1 still alive?
    consume(s1)
