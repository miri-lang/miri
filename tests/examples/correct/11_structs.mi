// SPDX-License-Identifier: Apache-2.0
// Demonstrates struct definition, instantiation with named fields, and field access.
use system.io

struct Point
    x int
    y int

fn distance_squared(p Point) int
    p.x * p.x + p.y * p.y

fn main()
    let p = Point(x: 3, y: 4)
    println(f"{p.x}")
    println(f"{p.y}")
    println(f"{distance_squared(p)}")
