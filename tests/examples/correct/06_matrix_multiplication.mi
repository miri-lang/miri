// Matrix Multiplication implementation (List based for stability).
use system.io
use system.time
use system.collections.list

fn main()
    let size = 3
    // Use List<int> instead of direct array literal to ensure stable RC
    var a = List<int>()
    a.push(1)
    a.push(2)
    a.push(3)
    a.push(4)
    a.push(5)
    a.push(6)
    a.push(7)
    a.push(8)
    a.push(9)
    
    var b = List<int>()
    b.push(9)
    b.push(8)
    b.push(7)
    b.push(6)
    b.push(5)
    b.push(4)
    b.push(3)
    b.push(2)
    b.push(1)
    
    var c = List<int>()
    var count = 0
    while count < 9
        c.push(0)
        count += 1
    
    let start = nanotime()
    var i = 0
    while i < size
        var j = 0
        while j < size
            var k = 0
            var sum = 0
            while k < size
                let val_a = a.element_at(i * size + k)
                let val_b = b.element_at(k * size + j)
                sum = sum + (val_a * val_b)
                k += 1
            c.set(i * size + j, sum)
            j += 1
        i += 1
    let end = nanotime()
    
    println("Result Matrix:")
    var r = 0
    while r < size
        var col = 0
        while col < size
            print(f"{c.element_at(r * size + col)} ")
            col += 1
        println()
        r += 1
    
    println(f"Time taken: {end - start} ns")
