// Classic FizzBuzz from 1 to 15 using match with guard conditions.
use system.io

fn fizzbuzz(n int) String
    match n
        x if x % 15 == 0: "FizzBuzz"
        x if x % 3 == 0: "Fizz"
        x if x % 5 == 0: "Buzz"
        x: f"{x}"

fn main()
    for i in 1..16
        println(fizzbuzz(i))
