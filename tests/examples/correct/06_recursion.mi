// SPDX-License-Identifier: Apache-2.0
// Demonstrates recursive function definitions: factorial and Fibonacci.
use system.io

fn factorial(n int) int
    if n <= 1: 1
    else: n * factorial(n - 1)

fn fib(n int) int
    if n <= 1: n
    else: fib(n - 1) + fib(n - 2)

fn main()
    println(f"{factorial(5)}")
    println(f"{fib(10)}")
