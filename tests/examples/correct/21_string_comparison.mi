// Demonstrates string equality and inequality operators.
use system.io

fn main()
    let a = "hello"
    let b = "hello"
    let c = "world"
    if a == b
        println("equal")
    if a != c
        println("not equal")
    println(f"{a == b}")
    println(f"{a == c}")
