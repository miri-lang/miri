// SPDX-License-Identifier: Apache-2.0
// Demonstrates typed function parameters: i8, f32, bool, and string.
use system.io
use system.string

fn double_i8(x i8) i8
    x * 2

fn half_f32(x f32) f32
    x / 2.0

fn negate_bool(b bool) bool
    not b

fn upper(s string) string
    s.to_upper()

fn main()
    let r1 = double_i8(21)
    println(f"{r1}")

    let r2 = half_f32(10.0)
    println(f"{r2}")

    let r3 = negate_bool(true)
    println(f"{r3}")

    let r4 = upper("hello")
    println(r4)
