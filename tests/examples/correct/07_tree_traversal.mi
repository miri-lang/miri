// Tree Traversal (DFS) implementation (Flat List based).
use system.io
use system.time
use system.collections.list

// In-order traversal using indices
fn dfs_inorder(values List<int>, lefts List<int>, rights List<int>, node_idx int)
    if node_idx == -1: return
    
    // Left
    dfs_inorder(values, lefts, rights, lefts.element_at(node_idx))
    
    // Visit
    print(f"{values.element_at(node_idx)} ")
    
    // Right
    dfs_inorder(values, lefts, rights, rights.element_at(node_idx))

fn main()
    // Manual tree construction indices:
    //      1 (0)
    //     / \
    //    2(1) 3(2)
    //   / \
    //  4(3) 5(4)
    
    var values = List<int>()
    var lefts = List<int>()
    var rights = List<int>()
    
    // Node 0: value 1, left 1, right 2
    values.push(1)
    lefts.push(1)
    rights.push(2)
    // Node 1: value 2, left 3, right 4
    values.push(2)
    lefts.push(3)
    rights.push(4)
    // Node 2: value 3, left -1, right -1
    values.push(3)
    lefts.push(-1)
    rights.push(-1)
    // Node 3: value 4, left -1, right -1
    values.push(4)
    lefts.push(-1)
    rights.push(-1)
    // Node 4: value 5, left -1, right -1
    values.push(5)
    lefts.push(-1)
    rights.push(-1)
    
    print("In-order DFS traversal: ")
    let start = nanotime()
    dfs_inorder(values, lefts, rights, 0)
    let end = nanotime()
    println()
    
    println(f"Time taken: {end - start} ns")
