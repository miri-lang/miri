// SPDX-License-Identifier: Apache-2.0
// Demonstrates until loop, do-while loop, and forever with break.
use system.io

fn main()
    var i = 0
    until i >= 5
        i = i + 1
    println(f"{i}")

    var count = 0
    do
        count = count + 1
    while count < 3
    println(f"{count}")

    var n = 0
    forever
        n = n + 1
        if n >= 4
            break
    println(f"{n}")
