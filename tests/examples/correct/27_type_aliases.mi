use system.io

type StringIntMap is {String: int}
type Coordinates is [int; 2]

struct CityData
    name String
    coords Coordinates
    population int

fn print_city(city CityData)
    println(f"City: {city.name}")
    println(f"Coords: {city.coords[0]}, {city.coords[1]}")

fn main()
    let populations StringIntMap = {"Metropolis": 5000000, "Smallville": 5000}

    let metro = CityData(name: "Metropolis", coords: [40, -74], population: populations["Metropolis"])
    print_city(city: metro)

    println(f"Population: {metro.population}")
