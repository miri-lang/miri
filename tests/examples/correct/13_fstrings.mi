// Demonstrates f-string interpolation with variables, expressions, and mixed types.
use system.io

fn main()
    let name = "World"
    let count = 42
    println(f"Hello, {name}!")
    println(f"Count: {count}")
    println(f"{count * 2} is double {count}")
    let x = 5
    let y = 3
    println(f"{x} + {y} = {x + y}")
