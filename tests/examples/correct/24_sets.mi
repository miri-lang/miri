use system.io
use system.collections.set

fn get_unique_numbers() Set<int>
    var s = {1, 2, 2, 3, 4, 4, 5}
    s.add(6)
    s.remove(3)
    return s

fn main()
    let unique = get_unique_numbers()

    println(f"Set has {unique.length()} elements")

    if 5 in unique
        println("Set contains 5")

    if unique.contains(3) == false
        println("Set does not contain 3")
