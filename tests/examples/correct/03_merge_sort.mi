// Merge Sort algorithm implementation.
use system.io
use system.time
use system.collections.list

// TODO: forward reference support!
fn merge(left List<int>, right List<int>) List<int>
    var result = List<int>()
    var i = 0
    var j = 0
    let n_l = left.length()
    let n_r = right.length()
    
    while i < n_l and j < n_r
        if left[i] <= right[j]
            result.push(left[i])
            i += 1
        else
            result.push(right[j])
            j += 1
            
    while i < n_l
        result.push(left[i])
        i += 1
    while j < n_r
        result.push(right[j])
        j += 1
        
    return result

fn merge_sort(l List<int>) List<int>
    let n = l.length()
    if n <= 1: return l
    
    let mid = n / 2
    var left = List<int>()
    var right = List<int>()
    
    var i = 0
    while i < mid
        left.push(l[i])
        i += 1
    while i < n
        right.push(l[i])
        i += 1
        
    left = merge_sort(left)
    right = merge_sort(right)
    
    return merge(left, right)

fn main()
    let data = List<int>()
    data.push(38)
    data.push(27)
    data.push(43)
    data.push(3)
    data.push(9)
    data.push(82)
    data.push(10)
    
    print("Unsorted list: ")
    for x in data: print(f"{x} ")
    println()
    
    let start = nanotime()
    let sorted = merge_sort(data)
    let end = nanotime()
    
    print("Sorted list:   ")
    for x in sorted: print(f"{x} ")
    println()
    println(f"Time taken: {end - start} ns")
