/// Time-related operations for Miri.

runtime "core" fn miri_rt_nanotime() int

/// Returns the current time in nanoseconds since an arbitrary starting point.
///
/// This can be used to measure the execution time of code fragments.
///
/// Example:
///     use system.time
///     let start = nanotime()
///     // code to measure
///     let end = nanotime()
///     println(f"Elapsed: {end - start} ns")
public fn nanotime() int
    return miri_rt_nanotime()
