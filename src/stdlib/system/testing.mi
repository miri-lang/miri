/// Test-only utilities for validating Miri's memory-safety infrastructure.
///
/// This module provides escape hatches that let integration tests verify the
/// MIRI_LEAK_CHECK detector fires correctly. Do not use these functions in
/// production code — they intentionally unbalance internal counters.

runtime "core" fn miri_rt_test_simulate_closure_leak()

/// Simulates a closure memory leak.
///
/// Increments the internal closure-allocation counter without allocating a
/// closure, so the MIRI_LEAK_CHECK atexit handler will report a spurious leak
/// when the process exits. Use in tests that verify the detector fires:
///
///     use system.io
///     use system.testing
///
///     fn main()
///         simulate_closure_leak()   // ← causes "leaked 1 closure allocation(s)"
public fn simulate_closure_leak()
    miri_rt_test_simulate_closure_leak()
